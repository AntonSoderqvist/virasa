[submodule "vendor/quill"]
	path = vendor/quill
	url = https://github.com/odygrd/quill.git
	ignore = dirty
[submodule "vendor/SDL"]
	path = vendor/SDL
	url = https://github.com/libsdl-org/SDL.git
	ignore = dirty
[submodule "vendor/googletest"]
	path = vendor/googletest
	url = https://github.com/google/googletest.git
	ignore = dirty
[submodule "vendor/freetype"]
	path = vendor/freetype
	url = https://gitlab.freedesktop.org/freetype/freetype.git
	ignore = dirty
[submodule "vendor/JetBrainsMono"]
	path = vendor/JetBrainsMono
	url = https://github.com/JetBrains/JetBrainsMono.git
	ignore = dirty
[submodule "vendor/glm"]
	path = vendor/glm
	url = https://github.com/g-truc/glm.git
	ignore = dirty
[submodule ".contracts"]
	path = .contracts
	url = git@github.com:AntonSoderqvist/virasa-contracts.git
